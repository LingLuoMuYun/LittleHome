---
interface Badge { name: string; color: string; }
interface Props { buildDate: string; badges: Badge[]; }
const { buildDate, badges } = Astro.props;
---

<!-- 底部状态看板 -->
<div class="dashboard card" id="site-dashboard">
  <span id="build-date-data" style="display:none">{buildDate}</span>
  <!-- 时钟 -->
  <div class="db-clock" id="db-clock">00:00:00</div>

  <!-- 运行天数 -->
  <div class="db-uptime">
    <span class="db-dot"></span>
    <span>已运行 <strong id="db-days">0</strong> 天</span>
  </div>

  <!-- 技术栈 -->
  <div class="db-badges">
    {badges.map((b) => (
      <span class="db-badge" style={`--badge-color: ${b.color}`}>{b.name}</span>
    ))}
  </div>
</div>

<script>
  const buildDate = new Date(document.getElementById('build-date-data')?.textContent || '');

  // 时钟
  function updateClock() {
    const now = new Date();
    const el = document.getElementById('db-clock');
    if (el) el.textContent = now.toLocaleTimeString('zh-CN', { hour12: false });
  }
  updateClock();
  setInterval(updateClock, 1000);

  // 运行天数
  function updateUptime() {
    const now = new Date();
    const diff = Math.floor((now.getTime() - buildDate.getTime()) / 86_400_000);
    const el = document.getElementById('db-days');
    if (el) el.textContent = String(isNaN(diff) ? 0 : diff);
  }
  updateUptime();
</script>

<style>
  .dashboard {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.75rem;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .db-clock {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: var(--text);
    background: linear-gradient(135deg, var(--accent), #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .db-uptime {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--text-secondary);
  }

  .db-uptime strong {
    color: var(--accent);
    font-weight: 700;
  }

  .db-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  .db-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .db-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25em 0.7em;
    border-radius: 8px;
    background: rgba(255,255,255,0.5);
    border: 1px solid var(--border);
    color: var(--badge-color);
  }

  html.dark .db-badge {
    background: rgba(51,65,85,0.5);
  }

  @media (max-width: 640px) {
    .dashboard {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
