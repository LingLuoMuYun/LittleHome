---
import { MusicProvider } from './music/MusicProvider';
import CloudPlayer from './music/CloudPlayer';
---

<div id="floating-player" class="floating-player">
  <button id="fp-toggle" class="fp-toggle" title="音乐">🎵</button>
  <div id="fp-panel" class="fp-panel hidden">
    <MusicProvider>
      <CloudPlayer client:load />
    </MusicProvider>
  </div>
</div>

<script>
  const KEY = 'lingluo-fp-visible';
  const panel = document.getElementById('fp-panel')!;
  const player = document.getElementById('floating-player')!;

  if (localStorage.getItem(KEY) !== 'hidden') {
    player.classList.remove('hidden');
    panel.classList.remove('hidden');
  }

  document.getElementById('fp-toggle')!.addEventListener('click', () => {
    panel.classList.toggle('hidden');
    localStorage.setItem(KEY, panel.classList.contains('hidden') ? 'hidden' : 'visible');
  });
</script>

<style>
  .floating-player {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 150;
    min-width: 56px;
  }

  .floating-player.hidden { display: none; }

  .fp-toggle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--accent);
    border: none;
    font-size: 1.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, opacity 0.2s;
  }

  .fp-toggle:hover { transform: scale(1.08); }

  .fp-panel {
    position: absolute;
    bottom: 56px;
    right: 0;
    width: 340px;
  }

  .fp-panel.hidden { display: none; }
</style>