---
import { site, social } from '../data/site';

interface Props {
  postCount: number;
  projectCount: number;
  photoCount: number;
}

const { postCount, projectCount, photoCount } = Astro.props;
const hasAvatar = !!site.avatarUrl;
---

<div class="profile-card card">
  <!-- 头像 -->
  <div class="avatar-ring">
    {hasAvatar ? (
      <img src={site.avatarUrl} alt={site.title} class="avatar-img" />
    ) : (
      <span class="avatar-text">{site.title[0]}</span>
    )}
  </div>

  <!-- 姓名 + 简介 -->
  <h1 class="profile-name">{site.title}</h1>
  <p class="profile-bio">{site.bio}</p>
  <p class="profile-subtitle">{site.subtitle}</p>

  <!-- 数据统计 -->
  <div class="stats-row">
    <div class="stat-item">
      <span class="stat-num" style="color: var(--accent)">{postCount}</span>
      <span class="stat-label">文章</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-num" style="color: #8b5cf6">{projectCount}</span>
      <span class="stat-label">项目</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-num" style="color: #ec4899">{photoCount}</span>
      <span class="stat-label">照片</span>
    </div>
  </div>

  <!-- 社交图标 -->
  <div class="social-row">
    {social.github && (
      <a href={social.github} target="_blank" rel="noopener" class="social-btn" title="GitHub" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
    )}
    {social.email && (
      <a href={social.email} class="social-btn" title="Email" aria-label="Email">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      </a>
    )}
    {social.qq && (
      <button class="social-btn social-reveal" title="QQ" aria-label="QQ" data-text={social.qq}>
        <span class="reveal-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.003 2c-2.265 0-6.29 1.364-6.29 7.325v1.195S3.55 14.96 3.55 17.474c0 .665.17 1.025.281 1.025.114 0 .902-.484 1.748-2.072 0 0-.18 2.197 1.904 3.967 0 0-1.77.495-2.943 1.473h2.088c1.32 0 1.856-.563 2.438-1.396.61.88 1.192 1.396 2.568 1.396h2.07c-1.174-.978-2.942-1.473-2.942-1.473 2.084-1.77 1.904-3.967 1.904-3.967.846 1.588 1.634 2.072 1.748 2.072.111 0 .282-.36.282-1.025 0-2.514-2.166-6.954-2.166-6.954V9.325C18.29 3.364 14.268 2 12.003 2z"/></svg>
        </span>
        <span class="reveal-text">{social.qq}</span>
      </button>
    )}
    {social.wechat && (
      <button class="social-btn social-reveal" title="微信" aria-label="微信" data-text={social.wechat}>
        <span class="reveal-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178A1.17 1.17 0 0 1 4.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178 1.17 1.17 0 0 1-1.162-1.178c0-.651.52-1.18 1.162-1.18zm3.042 4.046c-.774 0-1.534.127-2.253.372-2.133.725-3.693 2.728-3.693 5.097 0 2.958 2.383 5.358 5.32 5.358.25 0 .497-.02.742-.057l.437-.257a.62.62 0 0 1 .514-.068l1.372.804a.234.234 0 0 0 .12.039c.115 0 .208-.095.208-.212 0-.052-.014-.103-.034-.153l-.28-1.067a.425.425 0 0 1 .153-.478C18.883 18.37 20 16.76 20 14.95c0-2.776-2.417-4.913-5.36-4.913zm-1.64 3.04a.755.755 0 0 1 .748.76.754.754 0 0 1-.748.758.754.754 0 0 1-.748-.759c0-.42.335-.76.748-.76zm3.277 0a.755.755 0 0 1 .748.76.754.754 0 0 1-.748.758.754.754 0 0 1-.748-.759c0-.42.335-.76.748-.76z"/></svg>
        </span>
        <span class="reveal-text">{social.wechat}</span>
      </button>
    )}
  </div>
</div>

<script>
  document.querySelectorAll('.social-reveal').forEach((btn) => {
    let timer: number;
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const el = btn as HTMLElement;
      clearTimeout(timer);
      el.classList.add('revealed');
      timer = window.setTimeout(() => el.classList.remove('revealed'), 2000);
    });
  });
  // 点击其他地方收起
  document.addEventListener('click', () => {
    document.querySelectorAll('.social-reveal.revealed').forEach((el) => el.classList.remove('revealed'));
  });
</script>

<style>
  .profile-card {
    padding: 2.5rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100%;
  }

  .avatar-ring {
    width: 96px;
    height: 96px;
    border-radius: 20px;
    background: linear-gradient(135deg, #6366f1, #a855f7, #ec4899);
    padding: 4px;
    margin-bottom: 1.25rem;
    box-shadow: 0 8px 32px rgba(99, 102, 241, 0.3);
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 16px;
    object-fit: cover;
    display: block;
    background: #fff;
  }

  .avatar-text {
    width: 100%;
    height: 100%;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 800;
    color: #6366f1;
    background: #fff;
  }

  .profile-name {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    margin-bottom: 0.3rem;
  }

  .profile-bio {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.15rem;
    line-height: 1.5;
  }

  .profile-subtitle {
    font-size: 0.82rem;
    color: var(--text-secondary);
    opacity: 0.7;
    margin-bottom: 1.5rem;
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    transition: transform 0.2s;
  }

  .stat-item:hover {
    transform: scale(1.1);
  }

  .stat-num {
    font-size: 1.5rem;
    font-weight: 800;
    font-family: var(--font-mono);
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: var(--border);
  }

  .social-row {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .social-btn {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: rgba(255,255,255,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    transition: all 0.25s ease;
    border: 1px solid var(--border);
    cursor: pointer;
    font-family: inherit;
    overflow: hidden;
    white-space: nowrap;
    padding: 0;
  }

  html.dark .social-btn {
    background: rgba(51,65,85,0.5);
  }

  .social-btn:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
  }

  /* 展开显示 */
  .social-reveal {
    position: relative;
  }

  .social-reveal .reveal-text {
    display: none;
    font-size: 0.72rem;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    padding: 0 0.6rem;
  }

  .social-reveal .reveal-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 100%;
  }

  .social-reveal.revealed {
    width: auto;
    border-radius: 20px;
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
  }

  .social-reveal.revealed .reveal-icon {
    display: none;
  }

  .social-reveal.revealed .reveal-text {
    display: inline;
  }
</style>
