---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;
---

<!-- 文章轮播卡 — 展示单篇文章大图 -->
<div class="carousel-card card" id="post-carousel">
  <div class="carousel-slides" id="carousel-slides">
    {posts.map((post, i) => (
      <a
        href={`/posts/${post.id}`}
        class="carousel-slide"
        data-index={String(i)}
        style={`display: ${i === 0 ? 'block' : 'none'}`}
      >
        <div class="slide-bg">
          {post.data.cover ? (
            <img src={post.data.cover} alt="" class="slide-img" loading={i === 0 ? 'eager' : 'lazy'} />
          ) : (
            <div class="slide-placeholder"></div>
          )}
          <div class="slide-overlay"></div>
        </div>
        <div class="slide-content">
          <span class="slide-badge">LATEST</span>
          <div class="slide-tags">
            <span class="slide-cat">{post.data.category}</span>
            {post.data.tags.slice(0, 2).map((t) => <span class="slide-tag">{t}</span>)}
          </div>
          <h2 class="slide-title">{post.data.title}</h2>
          {post.data.description && (
            <p class="slide-desc">{post.data.description}</p>
          )}
          <time class="slide-date">
            {post.data.date.toLocaleDateString('zh-CN', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        </div>
      </a>
    ))}
  </div>

  <!-- 导航点 -->
  {posts.length > 1 && (
    <div class="carousel-dots" id="carousel-dots">
      {posts.map((_, i) => (
        <button
          class={`carousel-dot ${i === 0 ? 'active' : ''}`}
          data-index={String(i)}
          aria-label={`第 ${i + 1} 篇文章`}
        ></button>
      ))}
    </div>
  )}
</div>

{posts.length > 1 && (
  <script>
    const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
    const dots = document.querySelectorAll<HTMLButtonElement>('.carousel-dot');
    let current = 0;
    let timer: number;

    function show(idx: number) {
      slides.forEach((s, i) => { s.style.display = i === idx ? 'block' : 'none'; });
      dots.forEach((d, i) => { d.classList.toggle('active', i === idx); });
      current = idx;
    }

    function next() { show((current + 1) % slides.length); }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = parseInt(dot.dataset.index || '0');
        show(idx);
        clearInterval(timer);
        timer = setInterval(next, 5000);
      });
    });

    timer = setInterval(next, 5000);

    // 悬停暂停
    document.getElementById('post-carousel')?.addEventListener('mouseenter', () => clearInterval(timer));
    document.getElementById('post-carousel')?.addEventListener('mouseleave', () => { timer = setInterval(next, 5000); });
  </script>
)}

<style>
  .carousel-card {
    position: relative;
    overflow: hidden;
    min-height: 380px;
  }

  .carousel-slide {
    position: relative;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: #fff;
    cursor: pointer;
  }

  .slide-bg {
    position: absolute;
    inset: 0;
  }

  .slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s ease;
  }

  .carousel-slide:hover .slide-img {
    transform: scale(1.05);
  }

  .slide-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1e293b 0%, #334155 40%, #1e293b 100%);
  }

  .slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.1) 100%);
  }

  .slide-content {
    position: relative;
    z-index: 2;
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    min-height: 380px;
  }

  .slide-badge {
    display: inline-block;
    font-size: 0.55rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    background: rgba(99,102,241,0.85);
    backdrop-filter: blur(8px);
    color: #fff;
    padding: 0.25em 0.8em;
    border-radius: 20px;
    margin-bottom: 0.75rem;
    width: fit-content;
  }

  .slide-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-bottom: 0.6rem;
  }

  .slide-cat {
    font-size: 0.6rem;
    font-weight: 600;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    padding: 0.15em 0.6em;
    border-radius: 8px;
  }

  .slide-tag {
    font-size: 0.6rem;
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.15em 0.55em;
    border-radius: 8px;
  }

  .slide-title {
    font-size: 1.35rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 0.4rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: transform 0.3s;
  }

  .carousel-slide:hover .slide-title {
    transform: translateY(-2px);
  }

  .slide-desc {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.5;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .slide-date {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: rgba(255,255,255,0.5);
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(4px);
    padding: 0.2em 0.7em;
    border-radius: 10px;
    width: fit-content;
    border: 1px solid rgba(255,255,255,0.1);
  }

  /* 导航点 */
  .carousel-dots {
    position: absolute;
    bottom: 1.25rem;
    right: 1.5rem;
    z-index: 10;
    display: flex;
    gap: 0.4rem;
  }

  .carousel-dot {
    width: 1.5rem;
    height: 4px;
    border-radius: 2px;
    background: rgba(255,255,255,0.3);
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    padding: 0;
  }

  .carousel-dot.active {
    width: 2rem;
    background: #818cf8;
  }

  .carousel-dot:hover {
    background: rgba(255,255,255,0.6);
  }
</style>
