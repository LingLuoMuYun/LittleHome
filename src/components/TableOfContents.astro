<!-- 文章目录组件 - 纯客户端从 DOM 提取标题 -->
<nav id="toc" class="toc-nav">
  <ul id="toc-list"></ul>
</nav>

<script>
  function buildTOC() {
    const article = document.querySelector('.post-body');
    const tocList = document.getElementById('toc-list');
    if (!article || !tocList) return;

    const headings = article.querySelectorAll('h2, h3');
    if (headings.length === 0) {
      tocList.innerHTML = '<li class="toc-empty">无标题</li>';
      return;
    }

    const items: { el: HTMLHeadingElement; level: number; text: string; id: string }[] = [];
    headings.forEach((h) => {
      const el = h as HTMLHeadingElement;
      const level = parseInt(el.tagName[1]);
      const text = el.textContent || '';
      const id = text.replace(/\s+/g, '-').replace(/[^a-zA-Z0-9一-龥-]/g, '');
      el.id = id;
      items.push({ el, level, text, id });
    });

    let html = '';
    for (let i = 0; i < items.length; i++) {
      const item = items[i];
      const indent = item.level === 3 ? ' toc-indent' : '';
      html += `<li class="toc-item${indent}"><a href="#${item.id}">${item.text}</a></li>`;
    }
    tocList.innerHTML = html;
  }

  buildTOC();

  // 高亮当前标题
  const tocLinks = document.querySelectorAll('#toc-list a');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const id = entry.target.id;
        const link = document.querySelector(`#toc-list a[href="#${id}"]`);
        if (link) {
          link.classList.toggle('toc-visible', entry.isIntersecting);
        }
      });
    },
    { rootMargin: '-80px 0px -80% 0px' }
  );

  document.querySelectorAll('.post-body h2[id], .post-body h3[id]').forEach((h) => observer.observe(h));
</script>

<style>
  .toc-nav {
    font-size: 0.82rem;
  }

  #toc-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  #toc-list a {
    color: var(--text-secondary);
    display: block;
    padding: 0.2rem 0;
    transition: color 0.2s;
  }

  #toc-list a:hover,
  #toc-list a.toc-visible {
    color: var(--accent);
  }

  .toc-indent {
    padding-left: 0.8rem;
  }

  .toc-empty {
    color: var(--text-secondary);
    font-size: 0.82rem;
  }
</style>
