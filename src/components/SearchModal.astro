<!-- 全局搜索弹窗 -->
<div id="search-modal" class="search-modal hidden">
  <div class="search-bg"></div>
  <div class="search-dialog card">
    <div class="search-header">
      <input
        type="search"
        id="search-input"
        placeholder="搜索文章..."
        autocomplete="off"
        autofocus
      />
      <span class="search-shortcut">ESC</span>
    </div>
    <div id="search-results" class="search-results"></div>
    <div class="search-footer">
      <span class="search-hint">↑↓ 导航 · Enter 打开 · Esc 关闭</span>
    </div>
  </div>
</div>

<script>
  interface SearchItem { title: string; description: string; url: string; category: string; tags: string[]; }

  let searchItems: SearchItem[] = [];
  let selectedIdx = -1;

  // 从页面读取搜索索引
  const indexEl = document.getElementById('search-index');
  if (indexEl) {
    try { searchItems = JSON.parse(indexEl.textContent || '[]'); } catch(e) {}
  }

  function open(): void {
    const modal = document.getElementById('search-modal')!;
    modal.classList.remove('hidden');
    const input = document.getElementById('search-input') as HTMLInputElement;
    input.value = '';
    input.focus();
    renderResults(searchItems);
  }

  function close(): void {
    document.getElementById('search-modal')!.classList.add('hidden');
    selectedIdx = -1;
  }

  function renderResults(items: SearchItem[]): void {
    const container = document.getElementById('search-results')!;
    if (items.length === 0) {
      container.innerHTML = '<p class="search-empty">没有找到匹配的文章。</p>';
      return;
    }
    container.innerHTML = items.map((item, i) => `
      <a href="${item.url}" class="search-result ${i === selectedIdx ? 'selected' : ''}" data-idx="${i}">
        <span class="result-title">${highlight(item.title)}</span>
        <span class="result-category">${item.category}</span>
        <span class="result-desc">${highlight(item.description)}</span>
      </a>
    `).join('');
  }

  function highlight(text: string): string {
    const q = (document.getElementById('search-input') as HTMLInputElement).value.trim();
    if (!q) return text;
    const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return text.replace(re, '<mark>$1</mark>');
  }

  // 事件绑定
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      open();
      return;
    }

    const modal = document.getElementById('search-modal');
    if (!modal || modal.classList.contains('hidden')) return;

    if (e.key === 'Escape') { close(); return; }

    const results = document.querySelectorAll<HTMLElement>('.search-result');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      selectedIdx = Math.min(selectedIdx + 1, results.length - 1);
      renderFiltered();
    }
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      selectedIdx = Math.max(selectedIdx - 1, 0);
      renderFiltered();
    }
    if (e.key === 'Enter' && selectedIdx >= 0) {
      const link = results[selectedIdx] as HTMLAnchorElement;
      if (link) link.click();
    }
  });

  function renderFiltered(): void {
    const q = (document.getElementById('search-input') as HTMLInputElement).value.trim().toLowerCase();
    const filtered = searchItems.filter((item) =>
      !q || item.title.toLowerCase().includes(q) || item.description.toLowerCase().includes(q) || item.tags.some((t) => t.toLowerCase().includes(q))
    );
    renderResults(filtered);
  }

  document.getElementById('search-input')!.addEventListener('input', () => {
    selectedIdx = -1;
    renderFiltered();
  });

  document.getElementById('search-modal')!.querySelector('.search-bg')!.addEventListener('click', close);

  // 暴露出去（已不再需要 init）

</script>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    justify-content: center;
    padding-top: 12vh;
  }

  .search-modal.hidden { display: none; }

  .search-bg {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
    backdrop-filter: blur(4px);
  }

  .search-dialog {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 560px;
    margin: 0 1rem;
    padding: 1.25rem;
    max-height: 70vh;
    display: flex;
    flex-direction: column;
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .search-header input {
    flex: 1;
    padding: 0.65rem 0.85rem;
    font-size: 1rem;
    border: none;
    background: transparent;
    color: var(--text);
    outline: none;
  }

  .search-shortcut {
    font-size: 0.72rem;
    color: var(--text-secondary);
    background: var(--accent-light);
    padding: 0.15em 0.55em;
    border-radius: 4px;
    font-family: var(--font-mono);
  }

  .search-results {
    flex: 1;
    overflow-y: auto;
    max-height: 45vh;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .search-result {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.65rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: background 0.15s;
    cursor: pointer;
    border-bottom: none;
  }

  .search-result:hover,
  .search-result.selected {
    background: var(--accent-light);
  }

  .result-title {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text);
  }

  .result-category {
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 500;
  }

  .result-desc {
    font-size: 0.78rem;
    color: var(--text-secondary);
  }

  .search-result mark {
    background: var(--accent-light);
    color: var(--accent);
    border-radius: 2px;
  }

  .search-empty {
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.9rem;
    padding: 2rem 0;
  }

  .search-footer {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .search-hint {
    font-size: 0.72rem;
    color: var(--text-secondary);
    opacity: 0.7;
  }
</style>
