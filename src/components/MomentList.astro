<!-- 说说/微动态组件 - localStorage 持久化 -->
<form id="moment-form">
  <textarea
    id="moment-input"
    placeholder="此刻的想法..."
    rows="2"
    autocomplete="off"
  ></textarea>
  <div class="moment-form-row">
    <input type="text" id="moment-location" placeholder="位置（可选）" class="moment-location" />
    <button type="submit" class="btn-primary">发布</button>
  </div>
</form>
<div id="moments-list"></div>

<script>
  interface Moment {
    id: string;
    content: string;
    location: string;
    createdAt: number;
  }

  const KEY = 'lingluo-moments';
  let moments: Moment[] = [];

  function load(): Moment[] {
    try { const raw = localStorage.getItem(KEY); return raw ? JSON.parse(raw) : []; } catch { return []; }
  }
  function save(): void { localStorage.setItem(KEY, JSON.stringify(moments)); }

  function formatTime(ts: number): string {
    const d = new Date(ts), now = new Date();
    const diff = now.getTime() - d.getTime();
    if (diff < 60_000) return '刚刚';
    if (diff < 3_600_000) return `${Math.floor(diff / 60_000)} 分钟前`;
    if (diff < 86_400_000) return `${Math.floor(diff / 3_600_000)} 小时前`;
    if (diff < 604_800_000) return `${Math.floor(diff / 86_400_000)} 天前`;
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  }

  function escapeHtml(s: string): string {
    const d = document.createElement('div'); d.textContent = s; return d.innerHTML;
  }

  function render(): void {
    const container = document.getElementById('moments-list')!;
    if (moments.length === 0) {
      container.innerHTML = '<p class="empty-hint">还没说过话，发布第一条说说吧。</p>';
      return;
    }
    container.innerHTML = moments
      .sort((a, b) => b.createdAt - a.createdAt)
      .map((m) => `
        <article class="moment-item">
          <div class="moment-dot"></div>
          <div class="moment-body">
            <p>${escapeHtml(m.content)}</p>
            <div class="moment-meta">
              ${m.location ? `<span class="moment-loc">📍 ${escapeHtml(m.location)}</span>` : ''}
              <time>${formatTime(m.createdAt)}</time>
              <button data-delete="${m.id}" class="btn-icon" title="删除">&times;</button>
            </div>
          </div>
        </article>`)
      .join('');
  }

  function addMoment(content: string, location: string): void {
    moments.push({ id: crypto.randomUUID(), content: content.trim(), location: location.trim(), createdAt: Date.now() });
    save(); render();
  }

  function deleteMoment(id: string): void {
    moments = moments.filter((m) => m.id !== id);
    save(); render();
  }

  document.getElementById('moment-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const textarea = document.getElementById('moment-input') as HTMLTextAreaElement;
    const location = document.getElementById('moment-location') as HTMLInputElement;
    const text = textarea.value.trim();
    if (text) { addMoment(text, location.value); textarea.value = ''; location.value = ''; }
  });

  document.getElementById('moments-list')!.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest<HTMLButtonElement>('[data-delete]');
    if (btn) deleteMoment(btn.dataset.delete!);
  });

  moments = load(); render();
</script>

<style>
  #moment-form { margin-bottom: 2rem; }
  #moment-form textarea {
    width: 100%; padding: 0.75rem 0.9rem; font-size: 0.95rem; resize: vertical;
    line-height: 1.7; margin-bottom: 0.6rem;
  }
  .moment-form-row { display: flex; gap: 0.5rem; align-items: center; }
  .moment-location { flex: 1; padding: 0.5rem 0.75rem; font-size: 0.85rem; }
  .empty-hint { color: var(--text-secondary); font-size: 0.9rem; text-align: center; padding: 2rem 0; }

  .moment-item {
    display: flex; gap: 0.8rem; padding: 0.9rem 0; border-bottom: 1px solid var(--border);
    transition: background 0.2s, var(--transition-theme);
  }
  .moment-item:hover { background: var(--accent-light); }
  .moment-dot {
    width: 8px; height: 8px; border-radius: 50%; background: var(--accent);
    flex-shrink: 0; margin-top: 0.45rem;
  }
  .moment-body { flex: 1; min-width: 0; }
  .moment-body p { margin-bottom: 0.35rem; white-space: pre-wrap; word-break: break-word; font-size: 0.93rem; }
  .moment-meta { display: flex; align-items: center; gap: 0.6rem; font-size: 0.76rem; color: var(--text-secondary); flex-wrap: wrap; }
  .moment-loc { color: var(--accent); }
  .btn-icon {
    background: none; border: none; font-size: 1.25rem; cursor: pointer;
    color: var(--text-secondary); padding: 0; line-height: 1; transition: color 0.2s; border-radius: 4px;
    margin-left: auto;
  }
  .btn-icon:hover { color: #ef4444; }
</style>
