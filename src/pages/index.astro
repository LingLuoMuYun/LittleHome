---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = await getCollection('posts');
const sortedPosts = posts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout>
  <!-- 个人信息卡片 -->
  <section class="profile card">
    <div class="avatar">LL</div>
    <h1>LingLuo</h1>
    <p class="bio">
      开发者 · 极简主义者<br />
      专注于构建简洁高效的 Web 体验。
    </p>
    <div class="links">
      <a href="https://github.com" target="_blank" rel="noopener">GitHub</a>
      <span class="sep">·</span>
      <a href="mailto:lingluo@example.com">Email</a>
    </div>
  </section>

  <!-- 文章列表 -->
  <section class="section">
    <h2>文章</h2>
    {
      sortedPosts.length === 0 ? (
        <p class="empty-hint">暂无文章。</p>
      ) : (
        <div class="post-list">
          {sortedPosts.map((post) => (
            <a href={`/posts/${post.id}`} class="post-item card">
              <div class="post-item-top">
                <h3>{post.data.title}</h3>
                <span class="category-tag">{post.data.category}</span>
              </div>
              {post.data.description && <p>{post.data.description}</p>}
              <div class="post-item-bottom">
                <time>
                  {post.data.date.toLocaleDateString('zh-CN', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                {post.data.tags.length > 0 && (
                  <div class="tags">
                    {post.data.tags.map((t) => <span class="tag">{t}</span>)}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      )
    }
  </section>
</Layout>

<style>
  .profile {
    text-align: center;
    padding: 2.5rem 2rem;
    margin-bottom: 3rem;
  }

  .avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), #8b5cf6);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.35rem;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3);
  }

  .profile h1 {
    margin-bottom: 0.4rem;
  }

  .bio {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .links {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .links a {
    color: var(--accent);
  }

  .links a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .sep {
    margin: 0 0.6rem;
    color: var(--border);
  }

  .section {
    margin-bottom: 3rem;
  }

  .section h2 {
    margin-bottom: 1rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-item {
    display: block;
    padding: 1.15rem 1.35rem;
  }

  .post-item-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.2rem;
  }

  .post-item-top h3 {
    font-size: 1rem;
  }

  .category-tag {
    font-size: 0.72rem;
    background: var(--accent-light);
    color: var(--accent);
    padding: 0.12em 0.55em;
    border-radius: 10px;
    font-weight: 500;
    flex-shrink: 0;
  }

  .post-item p {
    color: var(--text-secondary);
    font-size: 0.88rem;
    margin-bottom: 0.35rem;
  }

  .post-item-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .post-item-bottom time {
    font-size: 0.78rem;
    color: var(--text-secondary);
    opacity: 0.8;
  }

  .tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.1em 0.5em;
    border-radius: 8px;
    transition: color 0.2s, border-color 0.2s;
  }

  .post-item:hover .tag {
    border-color: var(--accent);
    color: var(--accent);
  }

  .empty-hint {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }
</style>
