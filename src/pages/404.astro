---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="error-page">
    <div class="card error-card">
      <h1>404</h1>
      <p>页面不存在</p>
      <p class="error-sub">你访问的页面可能已被删除或移动。</p>
      <a href="/" class="btn-primary">&larr; 返回首页</a>
    </div>
  </section>
</Layout>

<style>
  .error-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 50vh;
  }

  .error-card {
    text-align: center;
    padding: 3rem 2.5rem;
    max-width: 400px;
  }

  .error-card h1 {
    font-size: 5rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent), #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
    letter-spacing: -0.03em;
  }

  .error-card p {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .error-sub {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-block;
    text-decoration: none;
    color: #fff;
    border-bottom: none;
  }

  .btn-primary:hover {
    color: #fff;
  }
</style>
