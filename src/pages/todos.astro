---
import Layout from '../layouts/Layout.astro';
import TodoList from '../components/TodoList.astro';
---

<Layout>
  <section class="page-header">
    <h1>待办</h1>
    <p class="subtitle">管理你的日常任务。</p>
  </section>
  <TodoList />
</Layout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
</style>
